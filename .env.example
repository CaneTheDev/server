# OpenRouter API Keys
OPENROUTER_API_KEY_ELIGIBILITY=your_key_here
OPENROUTER_API_KEY_NETWORKING=your_key_here

# Tavily Search API Key (LinkedIn, GitHub, Twitter profile discovery)
TAVILY_API_KEY=your_key_here

# GitHub Personal Access Token (for GitHub user search API)
GITHUB_TOKEN=your_key_here

# Production Settings
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-app.com
PORT=8000
