# Provider Selection: "cerebras" or "openrouter"
LLM_PROVIDER=openrouter

# OpenRouter Configuration
OPENROUTER_API_KEY_ELIGIBILITY=your_key_here
OPENROUTER_API_KEY_NETWORKING=your_key_here
MODEL_PRIMARY=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
MODEL_ULTRA=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Cerebras Configuration
CEREBRAS_API_KEYS=key1,key2,key3
CEREBRAS_MODEL=gpt-oss-120b

# Tavily Search API Key (LinkedIn, GitHub, Twitter profile discovery)
TAVILY_API_KEY=your_key_here

# GitHub Personal Access Token (for GitHub user search API)
GITHUB_TOKEN=your_key_here

# App Settings
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
PORT=8000